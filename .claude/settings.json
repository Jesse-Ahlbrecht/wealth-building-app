{
  "model": "opus",
  "enableAllProjectMcpServers": true,
  "env": {
    "FLASK_ENV": "development",
    "FLASK_DEBUG": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(curl *)",
      "Bash(tree *)",
      "Bash(echo *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(which *)",
      "Bash(env *)",
      "Bash(export *)",
      "Bash(source *)",
      "Bash(./run_backend.sh*)",
      "Bash(./run_local.sh*)",
      "Bash(./restart.sh*)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(ps *)",
      "Bash(sqlite3 *)",
      "Bash(psql *)",
      "Bash(createdb *)",
      "Bash(dropdb *)",
      "Bash(open *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(jq *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  }
}
